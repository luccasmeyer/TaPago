<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/top_bar_mt"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:navigationIcon="@drawable/arrow_back_ios_24dp"
        app:title="Suas fichas"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/list_sheet_workout_rv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/top_bar_mt"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/layout_sheet_workout_item"
        tools:itemCount="4"/>

    <include
        android:id="@+id/include_list_sheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        layout="@layout/layout_bottom_menu_view"/>

</androidx.constraintlayout.widget.ConstraintLayout>